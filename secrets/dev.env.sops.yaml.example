---
# Minimal bootstrap secrets for the *dev* environment. Rarely used in practice
# because the local stack runs with cleartext `.env` files (no public exposure).
# Useful when a teammate wants to share OpenAI / Anthropic / etc. keys without
# pinning them in a chat.

openai:
  api_key: REPLACE_ME

anthropic:
  api_key: REPLACE_ME

mailhog:
  smtp_password: ""  # mailhog accepts anything in dev; placeholder for parity
