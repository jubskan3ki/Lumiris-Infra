---
# Bootstrap secrets for production — copy to `prod.env.sops.yaml` (gitignored
# in cleartext form), fill in, then ENCRYPT before commit:
#
#   cp secrets/prod.env.sops.yaml.example secrets/prod.env.sops.yaml
#   $EDITOR secrets/prod.env.sops.yaml
#   sops -e -i secrets/prod.env.sops.yaml      # → encrypted in place, safe to commit
#
# All keys matching password|secret|key|token|dsn|url are obscured by the rule
# in ../.sops.yaml. Structure stays readable for code review.

infisical:
  ci_client_id: REPLACE_ME
  ci_client_secret: REPLACE_ME
  vps_client_id: REPLACE_ME
  vps_client_secret: REPLACE_ME
  project_id: REPLACE_ME

infisical_cloud:
  api_url: https://eu.infisical.com

cloudflare:
  api_token: REPLACE_ME
  account_id: REPLACE_ME

grafana_cloud:
  api_key: REPLACE_ME
  region: prod-eu-west-0

sentry:
  auth_token: REPLACE_ME
  org: lumiris

ghcr:
  username: jubs-kan3ki
  pat: REPLACE_ME  # GitHub PAT with write:packages scope, store separately from your user PAT

ssh:
  deploy_private_key: |
    -----BEGIN OPENSSH PRIVATE KEY-----
    REPLACE_ME
    -----END OPENSSH PRIVATE KEY-----

vps:
  ip: REPLACE_ME
  ssh_port: 2222
  ansible_user: ansible

discord:
  webhook_url: REPLACE_ME
