# Lumiris local infra — environment template.
# Copy to `.env` before running `docker compose up`.
# All values here are DEV-ONLY placeholders. Secret rule: "lumiris_local_dev_only".

# Versions des images (pinned)
TRAEFIK_VERSION=v3.2
POSTGRES_VERSION=17-alpine
REDIS_VERSION=7.4-alpine
MINIO_VERSION=RELEASE.2024-11-07T00-52-20Z
MAILHOG_VERSION=v1.0.1
GRAFANA_VERSION=11.3.1
PROMETHEUS_VERSION=v2.55.1
TEMPO_VERSION=2.6.0
LOKI_VERSION=3.2.1
PROMTAIL_VERSION=3.2.1
OTEL_COLLECTOR_VERSION=0.111.0
CADVISOR_VERSION=v0.49.1
NODE_EXPORTER_VERSION=v1.8.2
PGADMIN_VERSION=8.13
REDIS_COMMANDER_VERSION=latest

# Postgres
POSTGRES_USER=lumiris
POSTGRES_PASSWORD=lumiris_local_dev_only
POSTGRES_DB=lumiris
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=lumiris_local_dev_only
REDIS_PORT=6379

# MinIO (root)
MINIO_ROOT_USER=lumiris
MINIO_ROOT_PASSWORD=lumiris_local_dev_only
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# MinIO (app credentials créés par init-buckets.sh)
MINIO_APP_USER=lumiris-app
MINIO_APP_PASSWORD=lumiris_local_dev_only
MINIO_BUCKET_UPLOADS=lumiris-uploads
MINIO_BUCKET_CDN=lumiris-cdn
MINIO_BUCKET_BACKUPS=lumiris-backups

# Mailhog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# pgAdmin (profile tools)
PGADMIN_DEFAULT_EMAIL=admin@lumiris.local
PGADMIN_DEFAULT_PASSWORD=admin

# Traefik
TRAEFIK_DASHBOARD_PORT=8080
TRAEFIK_METRICS_PORT=8082

# Compose project name
COMPOSE_PROJECT_NAME=lumiris
