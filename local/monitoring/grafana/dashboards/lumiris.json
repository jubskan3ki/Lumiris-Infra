{
    "uid": "lumiris-overview",
    "title": "LUMIRIS — Ecosystem Overview",
    "tags": ["lumiris", "slo", "web-vitals"],
    "schemaVersion": 39,
    "version": 1,
    "editable": true,
    "timezone": "browser",
    "time": { "from": "now-6h", "to": "now" },
    "refresh": "30s",
    "templating": {
        "list": [
            {
                "name": "app",
                "type": "query",
                "label": "App",
                "datasource": { "type": "prometheus", "uid": "prometheus" },
                "query": "label_values(lumiris_web_vital_count, app)",
                "includeAll": true,
                "multi": true
            }
        ]
    },
    "panels": [
        {
            "type": "histogram",
            "title": "Iris Score Distribution",
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum by (le) (increase(lumiris_iris_score_bucket[$__range]))",
                    "format": "heatmap",
                    "legendFormat": "{{le}}"
                }
            ],
            "options": {
                "bucketSize": 10,
                "bucketOffset": 0,
                "combine": false
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "custom": { "fillOpacity": 80, "lineWidth": 1 }
                }
            }
        },
        {
            "type": "stat",
            "title": "Iris Score — by Grade (last 24h)",
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum by (grade) (increase(lumiris_iris_score_count[24h]))",
                    "legendFormat": "{{grade}}"
                }
            ],
            "options": {
                "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
                "colorMode": "background",
                "graphMode": "area"
            }
        },
        {
            "type": "timeseries",
            "title": "Audit Latency — /api/dpp/:id/score (p50/p95/p99)",
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "gridPos": { "x": 0, "y": 8, "w": 24, "h": 9 },
            "targets": [
                {
                    "refId": "A",
                    "expr": "lumiris:score_latency_p50_5m",
                    "legendFormat": "p50"
                },
                {
                    "refId": "B",
                    "expr": "lumiris:score_latency_p95_5m",
                    "legendFormat": "p95"
                },
                {
                    "refId": "C",
                    "expr": "lumiris:score_latency_p99_5m",
                    "legendFormat": "p99"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "orange", "value": 0.25 },
                            { "color": "red", "value": 0.5 }
                        ]
                    },
                    "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
                }
            }
        },
        {
            "type": "timeseries",
            "title": "Web Vitals — LCP p75 (per app)",
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "gridPos": { "x": 0, "y": 17, "w": 8, "h": 8 },
            "targets": [
                {
                    "refId": "A",
                    "expr": "histogram_quantile(0.75, sum by (app, le) (rate(lumiris_web_vital_bucket{name=\"LCP\", app=~\"$app\"}[5m])))",
                    "legendFormat": "{{app}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "ms",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "orange", "value": 2500 },
                            { "color": "red", "value": 4000 }
                        ]
                    }
                }
            }
        },
        {
            "type": "timeseries",
            "title": "Web Vitals — INP p75 (replaces FID, per app)",
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "gridPos": { "x": 8, "y": 17, "w": 8, "h": 8 },
            "targets": [
                {
                    "refId": "A",
                    "expr": "histogram_quantile(0.75, sum by (app, le) (rate(lumiris_web_vital_bucket{name=~\"INP|FID\", app=~\"$app\"}[5m])))",
                    "legendFormat": "{{app}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "ms",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "orange", "value": 200 },
                            { "color": "red", "value": 500 }
                        ]
                    }
                }
            }
        },
        {
            "type": "timeseries",
            "title": "Web Vitals — CLS p75 (per app)",
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "gridPos": { "x": 16, "y": 17, "w": 8, "h": 8 },
            "targets": [
                {
                    "refId": "A",
                    "expr": "histogram_quantile(0.75, sum by (app, le) (rate(lumiris_web_vital_bucket{name=\"CLS\", app=~\"$app\"}[5m])))",
                    "legendFormat": "{{app}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "none",
                    "decimals": 3,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "orange", "value": 0.1 },
                            { "color": "red", "value": 0.25 }
                        ]
                    }
                }
            }
        },
        {
            "type": "stat",
            "title": "API Availability — 30d SLO (target 99.9%)",
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "gridPos": { "x": 0, "y": 25, "w": 8, "h": 6 },
            "targets": [
                {
                    "refId": "A",
                    "expr": "lumiris:api_availability_30d",
                    "instant": true
                }
            ],
            "options": {
                "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
                "colorMode": "background",
                "graphMode": "none"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "decimals": 4,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "red", "value": null },
                            { "color": "orange", "value": 0.995 },
                            { "color": "green", "value": 0.999 }
                        ]
                    }
                }
            }
        },
        {
            "type": "timeseries",
            "title": "API Error Rate (5m)",
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "gridPos": { "x": 8, "y": 25, "w": 16, "h": 6 },
            "targets": [
                {
                    "refId": "A",
                    "expr": "lumiris:api_error_rate_5m / clamp_min(lumiris:api_request_rate_5m, 1)",
                    "legendFormat": "5xx ratio"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "orange", "value": 0.001 },
                            { "color": "red", "value": 0.01 }
                        ]
                    }
                }
            }
        },
        {
            "type": "logs",
            "title": "Sentry-mirrored Errors (Loki)",
            "datasource": { "type": "loki", "uid": "loki" },
            "gridPos": { "x": 0, "y": 31, "w": 24, "h": 8 },
            "targets": [
                {
                    "refId": "A",
                    "expr": "{job=\"sentry\"} |= \"error\""
                }
            ],
            "options": {
                "showTime": true,
                "wrapLogMessage": true,
                "dedupStrategy": "exact"
            }
        }
    ]
}
