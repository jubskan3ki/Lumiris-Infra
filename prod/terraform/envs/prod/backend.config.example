# Copy to backend.config (gitignored) and fill in once the R2 tfstate bucket
# exists. Then migrate:
#
#   terraform init -migrate-state -backend-config=envs/prod/backend.config
#
# The backend `s3` stanza in ../../backend.tf must be uncommented first.

bucket   = "lumiris-tfstate"
key      = "prod.tfstate"
region   = "auto"
endpoint = "https://REPLACE_ME.r2.cloudflarestorage.com"

# These two must come from the Cloudflare R2 API token (Account → R2 → Manage
# R2 API Tokens). Don't reuse the user-level Cloudflare API token.
access_key = "REPLACE_ME"
secret_key = "REPLACE_ME"

skip_credentials_validation = true
skip_metadata_api_check     = true
skip_region_validation      = true
skip_requesting_account_id  = true
use_path_style              = true
