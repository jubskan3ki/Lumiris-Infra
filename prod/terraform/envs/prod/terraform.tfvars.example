# Copy to terraform.tfvars (gitignored) and fill in. Then from prod/terraform/:
#
#   terraform init
#   terraform plan -var-file=envs/prod/terraform.tfvars
#   terraform apply -var-file=envs/prod/terraform.tfvars

domain        = "lumiris.eu"
contact_email = "ops@lumiris.eu"

# From Cloudflare → Manage Account → API Tokens. Needs Zone:Edit, DNS:Edit,
# R2:Edit and (for the custom domain) Workers Routes:Edit.
cloudflare_api_token  = "REPLACE_ME"
cloudflare_account_id = "REPLACE_ME"

# VPS reachability — set after the school hands over the box.
vps_ip   = "REPLACE_ME"
vps_ipv6 = ""

# Optional — leave empty to keep the monitoring module inert.
grafana_cloud_api_key = ""

# EU tenant. Change to https://app.infisical.com for the US/global tenant.
infisical_api_url = "https://eu.infisical.com"
